generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ImpactArea {
  ENVIRONMENTAL
  SOCIAL
  ECONOMIC
  TECHNICAL
  INDIVIDUAL
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImpactStatus {
  PROPOSED
  APPROVED
  IMPLEMENTED
  ARCHIVED
}

model ImpactItem {
  id          String       @id @default(cuid())
  title       String
  description String
  impactArea  ImpactArea
  likelihood  ImpactLevel
  severity    ImpactLevel
  status      ImpactStatus @default(PROPOSED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}